<file path="app/globals.css">
@import "tailwindcss";

@theme {
  --color-brand-black: #0E0E0E;
  --color-brand-purple: #836EF9;
  --color-brand-green: #00FF9D;
  --color-brand-white: #FFFFFF;
  --color-brand-gray: #888888;
  
  --font-sans: var(--font-space-grotesk);
  --font-mono: var(--font-space-mono);
  --font-display: var(--font-cinzel);
}

/* --- ANIMATIONS --- */

/* Glitch Effect */
@keyframes glitch {
  0% { transform: translate(0); text-shadow: -2px 0 #836EF9, 2px 0 #00FF9D; }
  25% { transform: translate(-2px, 2px); }
  50% { transform: translate(2px, -2px); text-shadow: 2px 0 #836EF9, -2px 0 #00FF9D; }
  75% { transform: translate(-2px, -2px); }
  100% { transform: translate(0); }
}

.animate-glitch {
  animation: glitch 0.3s cubic-bezier(.25,.46,.45,.94) both infinite;
}

/* Marquee Effect */
@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.animate-marquee {
  display: flex;
  width: max-content;
  animation: marquee 25s linear infinite;
}

/* Smooth Fade In Up */
.fade-in {
  animation: fadeIn 0.8s ease-out forwards;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Custom Selection Color */
::selection {
  background-color: #836EF9;
  color: #0E0E0E;
}
